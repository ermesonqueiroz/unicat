<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1A56A0"
        android:padding="14dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:paddingEnd="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Buscar"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/editbox_background"
            android:backgroundTint="#FFFFFF"
            android:orientation="horizontal"
            android:padding="9dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="18sp"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etBusca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Buscar gatos ou usuários..."
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- Filter Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tabTodos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#1A56A0"
                android:textColor="#FFFFFF"
                android:paddingHorizontal="15dp"
                android:paddingVertical="6dp"
                android:text="Todos"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tabGatos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:textColor="#6B7280"
                android:paddingHorizontal="15dp"
                android:paddingVertical="6dp"
                android:text="Gatos"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tabUsuarios"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:textColor="#6B7280"
                android:paddingHorizontal="15dp"
                android:paddingVertical="6dp"
                android:text="Usuários"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Results -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/itemMingau"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:padding="11dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="9dp">

                    <TextView android:layout_width="44dp" android:layout_height="44dp"
                        android:background="#E8F0FB" android:gravity="center"
                        android:text="🐱" android:textSize="22sp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Mingau" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Gato • Campus Unifor" android:textSize="12sp" android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemPretinha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:padding="11dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="9dp">

                    <TextView android:layout_width="44dp" android:layout_height="44dp"
                        android:background="#E8F0FB" android:gravity="center"
                        android:text="🐈" android:textSize="22sp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Pretinha" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Gato • Campus Unifor" android:textSize="12sp" android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/itemTigrao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:padding="11dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="9dp">

                    <TextView android:layout_width="44dp" android:layout_height="44dp"
                        android:background="#E8F0FB" android:gravity="center"
                        android:text="🐈‍⬛" android:textSize="22sp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tigrão" android:textStyle="bold" android:textSize="15sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Gato • Campus Unifor" android:textSize="12sp" android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Bottom Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:background="#FFFFFF"
        android:elevation="6dp"
        android:orientation="horizontal">

        <LinearLayout android:id="@+id/navMapa" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🗺️" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mapa" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navGatos" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🐱" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gatos" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navFeed" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📰" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Feed" android:textSize="10sp" android:textColor="#1A56A0" android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navPerfil" android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👤" android:textSize="22sp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Perfil" android:textSize="10sp" android:textColor="#6B7280"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
