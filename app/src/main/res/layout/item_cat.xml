<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?attr/selectableItemBackground"
    app:cardBackgroundColor="?attr/colorSurface"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgCatAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="center"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent" />

        <TextView
            android:id="@+id/tvCatName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/imgArrowIndicator"
            app:layout_constraintStart_toEndOf="@id/imgCatAvatar"
            app:layout_constraintTop_toTopOf="@id/imgCatAvatar"
            app:layout_constraintVertical_chainStyle="packed"
            tools:text="Mingau" />

        <TextView
            android:id="@+id/tvCatLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/imgCatAvatar"
            app:layout_constraintEnd_toEndOf="@id/tvCatName"
            app:layout_constraintStart_toStartOf="@id/tvCatName"
            app:layout_constraintTop_toBottomOf="@id/tvCatName"
            tools:text="📍 Bloco C" />

        <ImageView
            android:id="@+id/imgArrowIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/abc_ic_go_search_api_material"
            android:contentDescription="Ver detalhes"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorOnSurfaceVariant" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>